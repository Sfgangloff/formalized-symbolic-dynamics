{
  "permissions": {
    "defaultMode": "acceptEdits",
    "additionalDirectories": [],
    "allow": [
      "Bash(lake build*)",
      "Bash(lake env*)",
      "Bash(lake update*)",
      "Bash(lake exe*)",
      "Bash(elan show)",
      "Bash(uv run *)",
      "Bash(uv sync*)",
      "Bash(uv lock*)",
      "Bash(ruff *)",
      "Bash(pytest*)",
      "Bash(bash scripts/check_symbolic_dynamics_policy.sh)",
      "Bash(scripts/check_symbolic_dynamics_policy.sh)",
      "Bash(scripts/*.sh)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch)",
      "Bash(git branch --list*)",
      "Bash(git fetch*)",
      "Bash(git stash*)",
      "Bash(git ls-files*)",
      "Bash(git ls-tree*)",
      "Bash(git remote -v)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout -b *)",
      "Bash(git checkout main)",
      "Bash(git restore --staged *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(find . *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(stat *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(gh pr view*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr list*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh repo view*)",
      "Bash(gh api repos/*)",
      "WebSearch",
      "WebFetch(domain:arxiv.org)",
      "WebFetch(domain:leanprover-community.github.io)",
      "WebFetch(domain:leanprover.github.io)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:en.wikipedia.org)",
      "WebFetch(domain:proofwiki.org)",
      "WebFetch(domain:zbmath.org)",
      "WebFetch(domain:mathworld.wolfram.com)",
      "WebFetch(domain:oeis.org)",
      "mcp__lean-lsp-mcp",
      "mcp__symdyn-shifts",
      "mcp__symdyn-tilings",
      "mcp__symdyn-complexity",
      "mcp__symdyn-viz",
      "mcp__math-search",
      "mcp__math-compute",
      "mcp__math-viz",
      "mcp__proof-explorer",
      "mcp__commutative-diagrams"
    ],
    "ask": [
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git cherry-pick *)",
      "Bash(git branch -d *)",
      "Bash(git stash drop*)",
      "Bash(gh pr create*)",
      "Bash(gh pr edit*)",
      "Bash(gh pr comment*)",
      "Bash(gh issue create*)",
      "Bash(gh issue comment*)",
      "Bash(rm *)",
      "Bash(uv add *)",
      "Bash(uv remove *)",
      "mcp__meta-tools__develop_tool"
    ],
    "deny": [
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git push:*)",
      "Bash(git reset --hard*)",
      "Bash(git restore .)",
      "Bash(git restore --worktree .)",
      "Bash(git checkout .)",
      "Bash(git checkout --orphan*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D *)",
      "Bash(git commit --amend*)",
      "Bash(git tag -d *)",
      "Bash(*--no-verify*)",
      "Bash(*--no-gpg-sign*)",
      "Bash(git config user.*)",
      "Bash(git config --global *)",
      "Bash(gh repo delete*)",
      "Bash(gh repo edit --visibility*)",
      "Bash(gh pr close*)",
      "Bash(gh pr merge*)",
      "Bash(gh release delete*)",
      "Bash(sudo *)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(/etc/**)",
      "Read(~/.config/git/**)",
      "Edit(**/lake-manifest.json)",
      "Write(**/lake-manifest.json)",
      "Edit(**/uv.lock)",
      "Write(**/uv.lock)",
      "Edit(**/.git/**)",
      "Write(**/.git/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/bash-guard.sh", "timeout": 10 }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/edit-guard.sh", "timeout": 10 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/post-lean-edit.sh", "timeout": 60 }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/stop-verify.sh", "timeout": 180 },
          { "type": "command", "command": ".claude/hooks/notify.sh", "timeout": 10 }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/notify.sh", "timeout": 10 }
        ]
      }
    ]
  }
}
